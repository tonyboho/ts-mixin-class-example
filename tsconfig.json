{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "src",
        "plugins": [
            {
                "transform": "ts-mixin-class",
                "transformProgram": true
            },
            {
                "name": "ts-mixin-class/language-service-plugin"
            }
        ]
    },
    "include": ["src"]
}
